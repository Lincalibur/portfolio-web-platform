{
  "title": "Script Repository",
  "description": "Enterprise-grade automation demos — configure inputs and run browser-side simulations with realistic, varied output.",
  "scripts": [
    {
      "id": "asset_discovery",
      "filename": "asset_discovery.py",
      "title": "The Reconnaissance Tool",
      "tagline": "Modular passive reconnaissance & asset mapping",
      "description": "Enter a target domain to simulate CT log enumeration, parallel host probing, and JSON footprint export. Each run discovers a different asset set with live latency readings.",
      "highlights": [
        "Structured JSON logging",
        "API rate-limiting handling",
        "Concurrent network requests"
      ],
      "language": "python",
      "sourcePath": "/fixtures/scripts/asset_discovery.py",
      "delayMs": 280,
      "inputs": [
        {
          "id": "target",
          "label": "Target domain",
          "type": "text",
          "default": "portfolio.local",
          "placeholder": "example.com"
        }
      ]
    },
    {
      "id": "deploy_env",
      "filename": "deploy_env.sh",
      "title": "The DevOps Framework",
      "tagline": "Environmental configuration automation",
      "description": "Pick an environment to simulate Docker network provisioning, image pulls, and health-check retries. Service count and tags change per environment.",
      "highlights": [
        "Linux system automation",
        "Environmental isolation",
        "Defensive script design (set -euo pipefail)"
      ],
      "language": "bash",
      "sourcePath": "/fixtures/scripts/deploy_env.sh",
      "delayMs": 320,
      "inputs": [
        {
          "id": "environment",
          "label": "Environment",
          "type": "select",
          "default": "staging",
          "options": [
            { "value": "dev", "label": "Development" },
            { "value": "staging", "label": "Staging" },
            { "value": "production", "label": "Production" }
          ]
        }
      ]
    },
    {
      "id": "compliance_check",
      "filename": "compliance_check.yml",
      "title": "The Risk & Compliance Audit",
      "tagline": "Automated system hardening baseline",
      "description": "Choose an inventory group and compliance baseline. Runs simulate Ansible task output — including occasional permission findings under stricter baselines.",
      "highlights": [
        "Infrastructure-as-Code (IaC)",
        "Compliance baseline verification",
        "Security posture scanning"
      ],
      "language": "yaml",
      "sourcePath": "/fixtures/scripts/compliance_check.yml",
      "delayMs": 350,
      "inputs": [
        {
          "id": "inventory",
          "label": "Inventory group",
          "type": "select",
          "default": "application_servers",
          "options": [
            { "value": "application_servers", "label": "Application servers" },
            { "value": "edge_nodes", "label": "Edge nodes" },
            { "value": "data_plane", "label": "Data plane" }
          ]
        },
        {
          "id": "baseline",
          "label": "Compliance baseline",
          "type": "select",
          "default": "cis_level1",
          "options": [
            { "value": "cis_level1", "label": "CIS Level 1" },
            { "value": "pci_dss", "label": "PCI-DSS" },
            { "value": "custom_hard", "label": "Custom hardening" }
          ]
        }
      ]
    }
  ]
