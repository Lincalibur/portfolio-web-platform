# Copy to .env for Docker Compose (never commit .env)
ConnectionStrings__Default=Data Source=/data/resume.db
Jwt__SigningKey=replace_with_at_least_32_random_characters
Smtp__Host=
Smtp__Port=587
Smtp__UserName=
Smtp__Password=
Smtp__FromAddress=
Smtp__FromDisplayName=Portfolio Resume

# Frontend build (set in src/Portfolio.Web/.env.production or CI)
VITE_API_BASE_URL=
VITE_ENABLE_INTERACTION_METRICS=false
VITE_USE_HOST_STATS_API=false
